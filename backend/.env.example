# App Configuration
APP_PORT=5890
APP_HOST=127.0.0.1
APP_ENV=production

# Security (REQUIRED — generated automatically by install.sh)
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=7d

# CORS: only needed when frontend is served from a different origin.
# Single-service mode serves the UI and API on the same port, so leave default.
CORS_ORIGINS=http://localhost:5890

# Data directory (SQLite file + db-config.json live here).
# DATA_DIR=/var/lib/skygenpanel

# Database is configured at runtime via the Setup wizard / Settings > Database.
# Defaults to SQLite (no external DB required). To pin MySQL via env instead of
# the UI, the panel reads DATA_DIR/db-config.json which the UI writes.
