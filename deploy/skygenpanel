#!/usr/bin/env bash
#
# skygenpanel — management CLI for the SkyGenPanel service.
#
set -euo pipefail

INSTALL_DIR="${SKYGP_DIR:-/opt/skygenpanel}"
SERVICE_NAME="skygenpanel"
ENV_FILE="${INSTALL_DIR}/backend/.env"
REPO_BRANCH="${SKYGP_BRANCH:-main}"
CLI_PATH="${SKYGP_CLI_PATH:-/usr/local/bin/skygenpanel}"

log()  { printf '\033[1;34m[skygp]\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m[skygp]\033[0m %s\n' "$*" >&2; }
die()  { printf '\033[1;31m[skygp]\033[0m %s\n' "$*" >&2; exit 1; }

need_root() { [ "$(id -u)" -eq 0 ] || die "This command needs root (use sudo)."; }

validate_install_dir() {
  local resolved
  [[ "$INSTALL_DIR" = /* ]] || die "Install directory must be an absolute path: $INSTALL_DIR"
  resolved="$(realpath -m -- "$INSTALL_DIR")" || die "Unable to resolve install directory: $INSTALL_DIR"
  [ "$resolved" = "$INSTALL_DIR" ] || die "Install directory must be normalized and contain no symbolic-link components: $INSTALL_DIR"
  case "$INSTALL_DIR" in
    /|/bin|/boot|/dev|/etc|/home|/lib|/lib64|/opt|/proc|/root|/run|/sbin|/srv|/sys|/tmp|/usr|/var|/var/lib)
      die "Refusing unsafe install directory: $INSTALL_DIR"
      ;;
  esac
  [[ "$INSTALL_DIR" =~ ^/[A-Za-z0-9._/-]+$ ]] || die "Install directory contains unsupported characters: $INSTALL_DIR"
  [ ! -L "$INSTALL_DIR" ] || die "Install directory must not be a symbolic link."
  [ ! -L "$ENV_FILE" ] || die "Refusing symbolic-link env file: $ENV_FILE"
}

app_port() {
  local p
  p="$(grep -E '^APP_PORT=' "$ENV_FILE" 2>/dev/null | head -1 | cut -d= -f2)"
  echo "${p:-5890}"
}

set_env() {
  # set_env KEY VALUE — upsert a key in the env file
  local key="$1" value="$2"
  [ -f "$ENV_FILE" ] || die "Env file not found: $ENV_FILE"
  if grep -qE "^${key}=" "$ENV_FILE"; then
    sed -i "s|^${key}=.*|${key}=${value}|" "$ENV_FILE"
  else
    echo "${key}=${value}" >> "$ENV_FILE"
  fi
}

cmd_update() {
  local legacy_dir cli_temp
  need_root
  validate_install_dir
  [ -d "$INSTALL_DIR/.git" ] || die "Not a git checkout: $INSTALL_DIR"
  log "Fetching latest ($REPO_BRANCH)"
  git -C "$INSTALL_DIR" fetch --depth 1 origin "$REPO_BRANCH"
  git -C "$INSTALL_DIR" reset --hard "origin/$REPO_BRANCH"
  log "Removing legacy Next.js build artifacts"
  for legacy_dir in "$INSTALL_DIR/frontend/.next" "$INSTALL_DIR/frontend/out"; do
    [ ! -L "$legacy_dir" ] || die "Refusing symbolic-link legacy artifact: $legacy_dir"
    if [ -e "$legacy_dir" ]; then
      rm -rf -- "$legacy_dir"
    fi
  done
  [ ! -L "$CLI_PATH" ] || die "Refusing symbolic-link CLI path: $CLI_PATH"
  cli_temp="${CLI_PATH}.new.$$"
  trap 'rm -f -- "${cli_temp:-}"' EXIT
  install -m 0755 "$INSTALL_DIR/deploy/skygenpanel" "$cli_temp"
  mv -f -- "$cli_temp" "$CLI_PATH"
  trap - EXIT
  log "Updating backend dependencies"
  ( cd "$INSTALL_DIR/backend" && npm ci --omit=dev )
  log "Rebuilding frontend"
  ( cd "$INSTALL_DIR/frontend" && npm ci --include=dev && npm run build )
  chown -R root:root "$INSTALL_DIR"
  chmod 600 "$ENV_FILE"
  log "Restarting service"
  systemctl restart "$SERVICE_NAME"
  log "Update complete."
}

cmd_expose() {
  need_root
  validate_install_dir
  set_env APP_HOST "0.0.0.0"
  local port; port="$(app_port)"
  log "Panel will bind to 0.0.0.0:${port} (reachable from the network)."
  warn "Anyone on your network can now reach the panel. Ensure a strong admin password and a firewall."
  systemctl restart "$SERVICE_NAME"
  log "Done."
}

cmd_unexpose() {
  need_root
  validate_install_dir
  set_env APP_HOST "127.0.0.1"
  log "Panel restricted to localhost (127.0.0.1)."
  systemctl restart "$SERVICE_NAME"
  log "Done."
}

cmd_restart() { need_root; systemctl restart "$SERVICE_NAME"; log "Restarted."; }
cmd_start()   { need_root; systemctl start "$SERVICE_NAME"; log "Started."; }
cmd_stop()    { need_root; systemctl stop "$SERVICE_NAME"; log "Stopped."; }
cmd_status()  { systemctl status "$SERVICE_NAME" --no-pager; }
cmd_version() {
  local version commit
  [ -f "$INSTALL_DIR/package.json" ] || die "Package manifest not found: $INSTALL_DIR/package.json"
  version="$(node -p "require('${INSTALL_DIR}/package.json').version")"
  commit="$(git -C "$INSTALL_DIR" rev-parse --short=12 HEAD 2>/dev/null || echo unknown)"
  printf 'SkyGenPanel v%s (%s)\n' "$version" "$commit"
}
cmd_logs() {
  local lines="${1:-100}"
  [[ "$lines" =~ ^[0-9]+$ ]] || die "Log line count must be a positive integer."
  journalctl -u "$SERVICE_NAME" -n "$lines" -f
}

cmd_reset_password() {
  need_root
  validate_install_dir
  local user="${1:-}" pass="${2:-}"
  [ -n "$user" ] || die "Usage: skygenpanel reset-password <username> [newPassword]"
  if [ -z "$pass" ]; then
    read -r -s -p "New password: " pass
    printf '\n'
  fi
  [ -n "$pass" ] || die "Password cannot be empty."
  ( cd "$INSTALL_DIR/backend" && RESET_PASSWORD="$pass" node scripts/reset-password.js "$user" )
}

usage() {
  cat <<EOF
skygenpanel — manage the SkyGenPanel service

Usage: skygenpanel <command> [args]

Commands:
  update                      Pull latest code, rebuild, and restart
  expose                      Bind to 0.0.0.0 (allow network access) + restart
  unexpose                    Bind to 127.0.0.1 (localhost only) + restart
  restart | start | stop      Control the systemd service
  status                      Show service status
  version                     Show installed version and Git revision
  logs [N]                    Follow the last N log lines (default 100)
  reset-password <u> [p]      Reset password (prompts securely when omitted)
  help                        Show this help
EOF
}

case "${1:-help}" in
  update)          cmd_update ;;
  expose)          cmd_expose ;;
  unexpose)        cmd_unexpose ;;
  restart)         cmd_restart ;;
  start)           cmd_start ;;
  stop)            cmd_stop ;;
  status)          cmd_status ;;
  version|-v|--version) cmd_version ;;
  logs)            cmd_logs "${2:-100}" ;;
  reset-password)  cmd_reset_password "${2:-}" "${3:-}" ;;
  help|-h|--help)  usage ;;
  *)               warn "Unknown command: $1"; usage; exit 1 ;;
esac
